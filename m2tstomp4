find . -type f \( -iname '*.m2ts' \) -print0 | while IFS= read -r -d '' f; do
  out="${f%.*}.mp4"
  tmp="${out}.tmp.mp4"

  echo "Encoding: $f"

  ffmpeg -nostdin -hide_banner -loglevel error -nostats -y -i "$f" \
    -map 0:v:0 -map '0:a?' \
    -vf "bwdif=mode=send_frame:parity=tff" \
    -c:v libx265 -crf 24 -preset medium -tag:v hvc1 \
    -c:a aac -b:a 160k \
    -movflags +faststart \
    "$tmp" &&
  mv -f "$tmp" "$out" &&
  rm -f "$f" &&
  echo "Done: $out" || echo "FAILED: $f"
done
